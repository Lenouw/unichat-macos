<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Requis pour le moteur JavaScript V8 d'Electron -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Requis pour Electron (code non signé en mémoire) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Requis pour charger les plugins/modules natifs d'Electron -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Accès microphone pour les messages vocaux WhatsApp -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
  <!-- Accès caméra pour les appels vidéo -->
  <key>com.apple.security.device.camera</key>
  <true/>
</dict>
</plist>
